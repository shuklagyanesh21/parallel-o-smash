// =====================================================
// Process defaults (applied to every process)
// Memory and time scale with task.attempt so retries
// after OOM (137/140) or timeout (143) get more room.
// =====================================================

process {

    cpus   = { params.cpus }
    memory = { (params.memory as nextflow.util.MemoryUnit) * task.attempt }
    time   = { (params.time   as nextflow.util.Duration)   * task.attempt }

    // Retry on OOM-kill (137), SLURM OOM (140), or timeout (143).
    // Ignore other failures so the rest of the genomes keep running.
    errorStrategy = { task.exitStatus in [137, 140, 143] ? 'retry' : 'ignore' }
    maxRetries    = { params.max_retries }

    // Tag every process with the sample so logs are easy to follow
    cache = 'lenient'
}