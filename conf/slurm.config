// =====================================================
// SLURM executor profile
// =====================================================

process {
    executor       = 'slurm'
    // USR2 signal 30s before walltime expires lets antiSMASH attempt a clean
    // shutdown and produces a partial output we can inspect.
    clusterOptions = '--signal=USR2@30'
}

executor {
    // Allow up to N jobs queued at once. Tune for your cluster's policy.
    queueSize       = 50
    submitRateLimit = '10 sec'
}
