// =====================================================
// parallel-o-smash: top-level Nextflow configuration
// =====================================================

plugins {
    id 'nf-schema@2.2.0'
}

// -----------------------------------------------------
// Default parameters (override on CLI with --name value
// or via -params-file params.yml)
// -----------------------------------------------------
params {

    // ----- I/O -----
    input              = null                  // REQUIRED: FASTA glob (e.g. '/data/*.fasta') OR a .csv samplesheet (sample,fasta,gff)
    outdir             = 'results'             // top-level output directory
    gff_pattern        = 'genomic.gff'         // expected GFF filename beside each FASTA (glob mode)
    use_gff            = false                 // when true, pass --genefinding-gff3 for non-empty GFF entries

    // ----- Resources (per task) -----
    cpus               = 8
    memory             = '12 GB'
    time               = '72h'
    max_retries        = 1

    // ----- antiSMASH core options -----
    taxon                   = 'bacteria'        // bacteria | fungi
    genefinding_tool        = 'error'          // prodigal | prodigal-m | none | error (antiSMASH default: error)
    hmmdetection_strictness = 'relaxed'         // strict | relaxed | loose
    minlength               = 1000
    databases               = null              // path to antiSMASH databases (null => use bundled)
    extra_args              = ''                // free-form additional antiSMASH flags
    debug                   = false             // add --debug to antiSMASH (huge logs)

    // ----- antiSMASH preset -----
    // One of: fast | balanced | full | minimal
    // Individual toggles below (when set to true/false) OVERRIDE the preset.
    // Leave a toggle as `null` to inherit from the preset.
    as_preset          = 'fast'

    // ----- antiSMASH module toggles (null => inherit from preset) -----
    fullhmmer          = null
    clusterhmmer       = null
    tigrfam            = null
    cc_mibig           = null
    asf                = null
    cb_general         = null
    cb_subclusters     = null
    cb_knownclusters   = null
    pfam2go            = null
    rre                = null
    rre_cutoff         = 25.0
    smcog_trees        = null
    tfbs               = null
    cassis             = null
    allow_long_headers = null
    html_start_compact = null
    html_ncbi_context  = null

    // ----- Misc -----
    help               = false
    validate_params    = true
}

validation {
    parametersSchema        = 'nextflow_schema.json'
    failUnrecognisedParams  = true
    failUnrecognisedHeaders = true

    help {
        enabled = true
        command = 'nextflow run main.nf --input \'/path/to/genomes/*.fasta\' --outdir results -profile standard'
    }
}

// -----------------------------------------------------
// Include common process defaults + module-level config
// -----------------------------------------------------
includeConfig 'conf/base.config'
includeConfig 'conf/modules.config'

// -----------------------------------------------------
// Pipeline reports (auto-enabled)
// -----------------------------------------------------
def trace_ts = new java.text.SimpleDateFormat('yyyyMMdd_HHmmss').format(new Date())

report {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/report_${trace_ts}.html"
    overwrite = true
}

trace {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/trace_${trace_ts}.txt"
    overwrite = true
    fields    = 'task_id,hash,native_id,name,status,exit,submit,duration,realtime,%cpu,peak_rss,peak_vmem,rchar,wchar'
}

timeline {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/timeline_${trace_ts}.html"
    overwrite = true
}

dag {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/dag_${trace_ts}.html"
    overwrite = true
}

// -----------------------------------------------------
// Profiles: pick one or more with `-profile a,b`
// -----------------------------------------------------
profiles {

    standard {
        process.executor = 'local'
    }

    slurm {
        includeConfig 'conf/slurm.config'
    }

    docker {
        includeConfig 'conf/docker.config'
    }

    singularity {
        includeConfig 'conf/singularity.config'
    }
}

// -----------------------------------------------------
// Manifest
// -----------------------------------------------------
manifest {
    name            = 'parallel-o-smash'
    author          = 'Gyanesh Shukla'
    description     = 'Parallel antiSMASH 8 runs across many genomes, powered by Nextflow.'
    version         = '0.1.0'
    nextflowVersion = '>=23.10'
    mainScript      = 'main.nf'
    homePage        = 'https://github.com/your-org/parallel-o-smash'
}
